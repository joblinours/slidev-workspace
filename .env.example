# GitHub repository containing your Slidev presentations (format: username/repo-name)
GITHUB_REPO=your-username/your-slides-repo

# Optional: path within the repo where slide folders live (leave empty for root)
GITHUB_PATH=

# Personal Access Token for private repos (needs repo read access)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Base URL — use / for direct access, /subpath/ when behind a reverse proxy
BASE_URL=/

# Title displayed in the workspace UI sidebar
SLIDES_TITLE=Mes Présentations
